          "action": "retry",
          "max_attempts": 3,
          "final_failure_action": "abort_task"
        },
        "cancelled": {
          "prompt_id": "generic.cancelled",
          "action": "abort_task"
        }
      }
    },
    {
      "stage_id": "result",
      "slot_to_fill": null,
      "primary_prompt_id": "recharge.success",
      "prompt_template_vars": ["operator", "phone_number", "amount", "new_balance"],
      "expected_input_type": "none",
      "ui_config": {
        "screen": "result",
        "auto_advance_ms": 5000
      },
      "branches": {
        "auto_advance": {
          "action": "return_home"
        }
      }
