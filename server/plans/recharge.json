          "action": "retry",
          "sub_branches": {
            "change_operator": {
              "clear_slot": "operator",
              "next_stage": "select_operator"
            },
            "change_number": {
              "clear_slot": "phone_number",
              "next_stage": "enter_number"
            },
            "change_amount": {
              "clear_slot": "amount",
              "next_stage": "enter_amount"
            },
            "cancel": {
              "action": "abort_task"
            }
          }
        },
        "unrecognized": {
          "prompt_id": "generic.not_understood",
          "action": "retry",
          "attempt_3_action": "modality_switch"
        },
        "cancelled": {
