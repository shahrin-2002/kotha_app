{
  "plan_id": "cash_out_v1",
  "task_type": "cash_out",
  "required_slots": ["agent_name", "amount"],
  "max_retries_per_step": 3,
  "stages": [
    {
      "stage_id": "select_agent",
      "slot_to_fill": "agent_name",
      "primary_prompt_id": "cash_out.select_agent",
      "expected_input_type": "agent_name_or_tap",
      "ui_config": {
        "screen": "select_agent",
        "show_agent_tiles": true,
        "show_mic": true
      },
      "branches": {
        "valid_slot": {
          "action": "fill_slot",
          "next_stage": "enter_amount"
        },
        "ambiguous": {
          "prompt_id": "cash_out.agent_clarify",
          "action": "retry"
        },
        "unrecognized": {
          "prompt_id": "generic.not_understood",
          "action": "retry",
          "attempt_2_prompt_id": "generic.not_understood_2",
          "attempt_3_action": "modality_switch",
          "modality_switch_prompt_id": "generic.tap_icon_fallback"
        },
        "cancelled": {
          "prompt_id": "generic.cancelled",
          "action": "abort_task"
        },
        "silent": {
          "timeout_ms": 4000,
          "prompt_id": "generic.still_there",
          "second_timeout_ms": 4000,
          "fallback_action": "modality_switch",
          "modality_switch_prompt_id": "generic.tap_icon_fallback"
        },
        "help_request": {
          "prompt_id": "cash_out.agent_help",
          "action": "replay_prompt"
        },
        "repeat_request": {
          "action": "replay_prompt"
        },
        "change_request": {
          "action": "replay_prompt"
        }
      }
    },
    {
      "stage_id": "enter_amount",
      "slot_to_fill": "amount",
      "primary_prompt_id": "cash_out.how_much",
      "expected_input_type": "amount",
      "ui_config": {
        "screen": "enter_amount",
        "show_mic": true
      },
      "validation": {
        "min": 500,
        "max": 25000,
        "exceeds_balance_prompt_id": "cash_out.insufficient_balance",
        "below_min_prompt_id": "cash_out.below_minimum",
        "above_max_prompt_id": "cash_out.above_maximum"
      },
      "branches": {
        "valid_slot": {
          "action": "fill_slot",
          "next_stage": "confirm"
        },
        "ambiguous": {
          "prompt_id": "cash_out.amount_clarify",
          "action": "retry"
        },
        "unrecognized": {
          "prompt_id": "generic.not_understood",
          "action": "retry",
          "attempt_2_prompt_id": "generic.not_understood_2",
          "attempt_3_action": "modality_switch",
          "modality_switch_prompt_id": "generic.tap_icon_fallback"
        },
        "cancelled": {
          "prompt_id": "generic.cancelled",
          "action": "abort_task"
        },
        "silent": {
          "timeout_ms": 4000,
          "prompt_id": "generic.still_there",
          "second_timeout_ms": 4000,
          "fallback_action": "modality_switch"
        },
        "help_request": {
          "prompt_id": "cash_out.how_much",
          "action": "replay_prompt"
        },
        "repeat_request": {
          "action": "replay_prompt"
        },
        "change_request": {
          "clear_slot": "agent_name",
          "next_stage": "select_agent"
        }
      }
    },
    {
      "stage_id": "confirm",
      "slot_to_fill": null,
      "primary_prompt_id": "cash_out.confirm_readback",
      "prompt_template_vars": ["agent_name", "amount"],
      "expected_input_type": "yes_no",
      "ui_config": {
        "screen": "confirm",
        "show_green_check": true,
        "show_red_x": true,
        "show_mic": true
      },
      "branches": {
        "confirmed": {
          "action": "next_stage",
          "next_stage": "pin_entry"
        },
        "denied": {
          "prompt_id": "cash_out.what_to_change",
          "action": "retry",
          "sub_branches": {
            "change_agent": {
              "clear_slot": "agent_name",
              "next_stage": "select_agent"
            },
            "change_amount": {
              "clear_slot": "amount",
              "next_stage": "enter_amount"
            },
            "cancel": {
              "action": "abort_task"
            }
          }
        },
        "unrecognized": {
          "prompt_id": "generic.not_understood",
          "action": "retry",
          "attempt_3_action": "modality_switch"
        },
        "cancelled": {
          "prompt_id": "generic.cancelled",
          "action": "abort_task"
        },
        "silent": {
          "timeout_ms": 4000,
          "prompt_id": "generic.still_there"
        },
        "help_request": {
          "action": "replay_prompt"
        },
        "repeat_request": {
          "action": "replay_prompt"
        }
      }
    },
    {
      "stage_id": "pin_entry",
      "slot_to_fill": null,
      "primary_prompt_id": "cash_out.enter_pin",
      "expected_input_type": "pin",
      "ui_config": {
        "screen": "pin_pad",
        "show_large_numpad": true,
        "show_mic": false
      },
      "branches": {
        "valid_slot": {
          "action": "execute_transaction",
          "next_stage": "result"
        },
        "denied": {
          "prompt_id": "cash_out.wrong_pin",
          "action": "retry",
          "max_attempts": 3,
          "final_failure_action": "abort_task"
        },
        "cancelled": {
          "prompt_id": "generic.cancelled",
          "action": "abort_task"
        }
      }
    },
    {
      "stage_id": "result",
      "slot_to_fill": null,
      "primary_prompt_id": "cash_out.success",
      "prompt_template_vars": ["agent_name", "amount", "new_balance"],
      "expected_input_type": "none",
      "ui_config": {
        "screen": "result",
        "auto_advance_ms": 5000
      },
      "branches": {
        "auto_advance": {
          "action": "return_home"
        }
      }
    }
  ]
}
